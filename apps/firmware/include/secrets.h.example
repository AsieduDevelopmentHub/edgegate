#define WIFI_STA_SSID "YourHomeWiFi-2.4G"
#define WIFI_STA_PASSWORD "your-wifi-password"

// Your PC's LAN IP running the backend (ipconfig)
#define BACKEND_HOST "192.168.1.202"
