# ==========================================================
# EdgeGate Environment Configuration
#
# Copy:
# .env.example → .env
#
# Example:
# cp .env.example .env
#
# Environment Modes:
#
# LOCAL DEVELOPMENT
# → SQLite
# → Direct backend access
#
# DOCKER / PRODUCTION
# → PostgreSQL
# → Redis
# → NGINX reverse proxy
#
# ==========================================================



# ==========================================================
# Application Mode
# ==========================================================

# true  → Local development
# false → Docker / production

LOCAL_DEV=true



# ==========================================================
# Database Configuration
# ==========================================================

# ------------------------------------------
# Local Development (SQLite)
#
# Tables are created automatically
# on application startup.
# ------------------------------------------

DATABASE_URL=sqlite+aiosqlite:///./edgegate.db



# ------------------------------------------
# Docker / Production (PostgreSQL)
#
# Uncomment below when using Docker.
# ------------------------------------------

# POSTGRES_USER=edgegate

# POSTGRES_PASSWORD=replace_with_secure_password

# POSTGRES_DB=edgegate

# DATABASE_URL=postgresql+asyncpg://edgegate:replace_with_secure_password@localhost:5432/edgegate



# ==========================================================
# Redis
# ==========================================================

# Redis cache and realtime layer

REDIS_URL=redis://localhost:6379/0



# ==========================================================
# Backend Configuration
# ==========================================================

# Generate using:
#
# python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=replace_with_secure_64_character_secret



# Gateway JWT signing secret
#
# Generate using:
#
# python -c "import secrets; print(secrets.token_urlsafe(48))"

GATEWAY_JWT_SECRET=replace_with_gateway_jwt_secret



# Allowed frontend origins
#
# Multiple values:
# comma-separated

CORS_ORIGINS=http://localhost:3000,http://localhost



# Backend API prefix

API_PREFIX=/api



# ==========================================================
# Dashboard Configuration
# ==========================================================

# ------------------------------------------
# Local Development
#
# Dashboard → Backend Direct
# ------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8000

NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws



# ------------------------------------------
# Docker / Production
#
# Dashboard → NGINX → Backend
#
# Uncomment below for Docker
# ------------------------------------------

# NEXT_PUBLIC_API_URL=http://localhost/api

# NEXT_PUBLIC_WS_URL=ws://localhost/ws



# ==========================================================
# Gateway Configuration
#
# Used by firmware provisioning
# and authentication.
# ==========================================================

GATEWAY_UUID=00000000-0000-0000-0000-000000000001

GATEWAY_NAME=edgegate-01



# Backend endpoint
#
# Local:
# http://192.168.x.x:8000/api
#
# Production:
# https://your-domain.com/api

BACKEND_URL=https://your-backend.example.com/api



# ==========================================================
# Firmware Access Point
# ==========================================================

# Gateway AP (clients connect here)

WIFI_AP_SSID=EdgeGate-AP

WIFI_AP_PASSWORD=replace_with_strong_password



# ==========================================================
# Firmware STA (Internet Uplink)
# ==========================================================

# Must be a 2.4 GHz network
#
# ESP32-C3 DOES NOT support 5 GHz

WIFI_STA_SSID=YourHomeWiFi

WIFI_STA_PASSWORD=YourHomePassword



# ==========================================================
# Quick Start
#
# Local:
#
# LOCAL_DEV=true
# DATABASE_URL=sqlite+aiosqlite:///./edgegate.db
#
# Docker:
#
# docker compose up -d
#
# ==========================================================