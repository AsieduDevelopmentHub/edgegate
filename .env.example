# Local dev (no Docker): SQLite — tables auto-created on startup
DATABASE_URL=sqlite+aiosqlite:///./edgegate.db
LOCAL_DEV=true

# Docker / production: PostgreSQL
# POSTGRES_USER=edgegate
# POSTGRES_PASSWORD=edgegate_secret
# POSTGRES_DB=edgegate
# DATABASE_URL=postgresql+asyncpg://edgegate:edgegate_secret@localhost:5432/edgegate

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
SECRET_KEY=change-me-to-a-random-64-char-string
GATEWAY_JWT_SECRET=change-me-gateway-jwt-secret
CORS_ORIGINS=http://localhost:3000,http://localhost
API_PREFIX=/api

# Dashboard — local dev (direct to backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Dashboard — Docker (via Nginx)
# NEXT_PUBLIC_API_URL=http://localhost/api
# NEXT_PUBLIC_WS_URL=ws://localhost/ws

# Firmware (set in platformio.ini build_flags or secrets.h)
GATEWAY_UUID=00000000-0000-0000-0000-000000000001
GATEWAY_NAME=edgegate-01
BACKEND_URL=https://your-backend.example.com/api
WIFI_AP_SSID=EdgeGate-AP
WIFI_AP_PASSWORD=edgegate123
WIFI_STA_SSID=YourHomeWiFi
WIFI_STA_PASSWORD=YourHomePassword

